# ─────────────────────────────────────────────────────────────────────────────
# Gestão Financeira Pessoal — environment template
# Copy to `.env.local` and fill with your personal Supabase project values.
# `.env.local` is gitignored; NEVER commit real keys. (SEC-02)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL.
#  - Local stack: printed by `supabase start` (e.g. http://127.0.0.1:54321)
#  - Remote:      Supabase dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_...). RLS-safe; SAFE to ship to the browser.
# New Supabase projects (post-Nov 2025) expose this in
# Project Settings → API Keys → Publishable. On older projects this is the anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...). SERVER-ONLY — bypasses RLS. NEVER prefix with
# NEXT_PUBLIC_ and never import into a Client Component (guard with `import 'server-only'`).
# Phase 1 likely needs this for nothing (the signup seed runs via a DB trigger).
SUPABASE_SECRET_KEY=
